# Your deployer wallet private key (without 0x prefix is fine)
# NEVER commit this file with real values — it's in .gitignore
PRIVATE_KEY=your_private_key_here

# Alchemy API key for Sepolia RPC
# Get one free at https://alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Etherscan API key for contract verification (optional)
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Set to "true" to enable gas reporting in tests
REPORT_GAS=false
