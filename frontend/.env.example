# Deployed Credencea contract address (from: npx hardhat run scripts/deploy.ts --network sepolia)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Chain ID: 11155111 = Sepolia, 31337 = Hardhat localhost
VITE_CHAIN_ID=11155111

# Reown (WalletConnect) Project ID
# Get one free at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=your_reown_project_id_here

# Pinata API credentials for IPFS uploads
# Get keys at https://pinata.cloud → API Keys
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_here
VITE_PINATA_JWT=your_pinata_jwt_here

# Public gateway for IPFS content (used for display)
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
